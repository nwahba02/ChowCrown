# MongoDB connection string (required). Get this from MongoDB Atlas → Connect → Drivers.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://..."

# Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Public URL of the app — written into generated QR code URLs.
APP_URL="http://localhost:3000"

# Port the Express API server listens on. Vite proxies /api to this port in dev.
API_PORT=3001

# Resend API key used to send contact-form notification emails.
# Get one from resend.com → API Keys. Leave unset to skip sending (submission is still saved to MongoDB).
RESEND_API_KEY=""

# If set, POST /api/tokens/generate requires an x-admin-key: <value> header.
# Leave unset during local development.
ADMIN_KEY=""

# Set to "production" when deploying. The server will refuse to start without
# ADMIN_KEY when NODE_ENV=production.
NODE_ENV="development"
